---
import { site, navLinks } from "../data/site";
import { features } from "../config";
---

<header
  id="site-nav"
  class="fixed inset-x-0 top-0 z-50"
  data-nav
>
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <!-- Brand -->
    <a
      href="#top"
      class="group flex items-center gap-2 text-sm font-semibold tracking-tight text-mist"
    >
      <img
        src="/favicon.png"
        alt={`${site.name} monogram`}
        width="32"
        height="32"
        class="h-8 w-8 rounded-lg object-cover ring-1 ring-accent/30 transition group-hover:ring-accent/60"
      />
      <span>{site.name}</span>
    </a>

    <!-- Desktop links -->
    <ul class="hidden items-center gap-8 md:flex">
      {
        navLinks.map((l) => (
          <li>
            <a
              href={l.href}
              class="text-sm font-medium text-haze transition-colors hover:text-mist"
            >
              {l.label}
            </a>
          </li>
        ))
      }
      {
        features.blog && (
          <li>
            <a
              href="/blog"
              class="text-sm font-medium text-haze transition-colors hover:text-mist"
            >
              Blog
            </a>
          </li>
        )
      }
      <li>
        <button
          type="button"
          class="grid h-9 w-9 place-items-center rounded-full text-haze ring-1 ring-line transition hover:bg-veil hover:text-mist"
          aria-label="Toggle color theme"
          data-theme-toggle
        >
          <svg class="theme-icon-sun h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="4" />
            <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" />
          </svg>
          <svg class="theme-icon-moon h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" />
          </svg>
        </button>
      </li>
      <li>
        <a
          href="#contact"
          class="rounded-full bg-accent px-4 py-2 text-sm font-semibold text-white shadow-lg shadow-accent/20 transition hover:bg-accent/90"
        >
          Get in touch
        </a>
      </li>
    </ul>

    <!-- Mobile controls -->
    <div class="flex items-center gap-1 md:hidden">
      <button
        type="button"
        class="grid h-9 w-9 place-items-center rounded-full text-haze ring-1 ring-line transition hover:bg-veil hover:text-mist"
        aria-label="Toggle color theme"
        data-theme-toggle
      >
        <svg class="theme-icon-sun h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4" />
          <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" />
        </svg>
        <svg class="theme-icon-moon h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" />
        </svg>
      </button>
      <button
        type="button"
        class="grid h-9 w-9 place-items-center text-mist"
        aria-label="Toggle menu"
        aria-expanded="false"
        data-menu-toggle
      >
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div
    class="hidden border-t border-line bg-ink/95 backdrop-blur md:!hidden"
    data-mobile-menu
  >
    <ul class="mx-auto flex max-w-6xl flex-col gap-1 px-6 py-4">
      {
        navLinks.map((l) => (
          <li>
            <a
              href={l.href}
              class="block rounded-lg px-3 py-2 text-base font-medium text-haze transition hover:bg-veil hover:text-mist"
              data-mobile-link
            >
              {l.label}
            </a>
          </li>
        ))
      }
      {
        features.blog && (
          <li>
            <a
              href="/blog"
              class="block rounded-lg px-3 py-2 text-base font-medium text-haze transition hover:bg-veil hover:text-mist"
              data-mobile-link
            >
              Blog
            </a>
          </li>
        )
      }
      <li class="pt-2">
        <a
          href="#contact"
          class="block rounded-full bg-accent px-4 py-2 text-center text-base font-semibold text-white"
          data-mobile-link
        >
          Get in touch
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  // (Theme-toggle handling lives in Layout.astro so it works on every page.)

  // Solidify the nav background once the user scrolls past the hero fold.
  // Styling lives in the `.nav-scrolled` CSS class so the bottom border can
  // animate from transparent → line colour without a width/colour flash.
  const nav = document.querySelector<HTMLElement>("[data-nav]");
  const onScroll = () => {
    nav?.classList.toggle("nav-scrolled", window.scrollY > 24);
  };
  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });

  // Mobile menu toggle.
  const toggle = document.querySelector<HTMLButtonElement>("[data-menu-toggle]");
  const menu = document.querySelector<HTMLElement>("[data-mobile-menu]");
  const setOpen = (open: boolean) => {
    if (!menu || !toggle) return;
    menu.classList.toggle("hidden", !open);
    toggle.setAttribute("aria-expanded", String(open));
  };
  toggle?.addEventListener("click", () => {
    const open = toggle.getAttribute("aria-expanded") === "true";
    setOpen(!open);
  });
  document
    .querySelectorAll("[data-mobile-link]")
    .forEach((a) => a.addEventListener("click", () => setOpen(false)));
</script>
