---
interface Props {
  eyebrow: string;
  title: string;
}
const { eyebrow, title } = Astro.props;
---

<div class="mb-12 max-w-2xl" data-reveal>
  <p class="mb-3 flex items-center gap-3 text-sm font-semibold uppercase tracking-[0.2em] text-accent">
    <span class="h-px w-8 bg-accent/60"></span>
    {eyebrow}
  </p>
  <h2 class="text-3xl font-bold tracking-tight text-mist sm:text-4xl">
    {title}
  </h2>
</div>
