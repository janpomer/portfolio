---
import { primaryStack, secondaryStack, type Tech } from "../data/stack";
import SectionHeading from "./SectionHeading.astro";
import TechIcon from "./TechIcon.astro";

const groups: { label: string; items: Tech[] }[] = [
  { label: "Primary", items: primaryStack },
  { label: "Secondary", items: secondaryStack },
];
---

<section id="stack" class="relative mx-auto max-w-6xl px-6 py-24 sm:py-32">
  <SectionHeading eyebrow="Toolbox" title="Tech stack" />

  <div class="space-y-10">
    {
      groups.map((group) => (
        <div>
          <h3
            class="mb-4 flex items-center gap-3 text-sm font-semibold uppercase tracking-[0.2em] text-haze"
            data-reveal
          >
            {group.label}
            <span class="h-px flex-1 bg-line" />
          </h3>

          <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-6">
            {group.items.map((tech, i) => (
              <div
                class="group flex flex-col items-center gap-3 rounded-2xl border border-line bg-surface/40 p-6 text-center transition duration-300 hover:-translate-y-1 hover:border-accent/30 hover:bg-surface/70"
                data-reveal
                style={`--reveal-delay:${i * 60}ms`}
              >
                <span class="text-accent transition-transform duration-300 group-hover:scale-110">
                  <TechIcon name={tech.icon} />
                </span>
                <span class="text-sm font-medium text-mist">{tech.name}</span>
              </div>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>
