---
import { site } from "../data/site";
const year = new Date().getFullYear();
---

<!-- Contact CTA -->
<section id="contact" class="relative mx-auto max-w-6xl px-6 py-24 sm:py-28">
  <div
    class="relative overflow-hidden rounded-3xl border border-white/10 bg-gradient-to-br from-secondary via-primary to-primary px-8 py-14 text-center sm:px-16"
    data-reveal
    style="--c-mist:#ffffff;--c-haze:#cdddf0"
  >
    <!-- glow -->
    <div class="pointer-events-none absolute -top-24 left-1/2 h-48 w-48 -translate-x-1/2 rounded-full bg-accent/30 blur-3xl" aria-hidden="true"></div>

    <h2 class="relative text-3xl font-bold tracking-tight text-white sm:text-4xl">
      Let's build something solid.
    </h2>
    <p class="relative mx-auto mt-4 max-w-xl text-lg text-haze">
      Have an architecture challenge, a blockchain product, or a team that needs
      technical leadership? I'd love to hear about it.
    </p>
    <div class="relative mt-8 flex flex-wrap items-center justify-center gap-4">
      <a
        href={`mailto:${site.email}`}
        class="inline-flex items-center gap-2 rounded-full bg-accent px-7 py-3.5 text-base font-semibold text-white shadow-xl shadow-accent/25 transition hover:-translate-y-0.5 hover:bg-accent/90"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="5" width="18" height="14" rx="2" /><path d="m3 7 9 6 9-6" />
        </svg>
        {site.email}
      </a>
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="border-t border-line">
  <div class="mx-auto flex max-w-6xl flex-col items-center gap-6 px-6 py-10 sm:flex-row sm:justify-between">
    <p class="text-sm text-haze">
      © {year} {site.name}. All rights reserved.
    </p>

    <div class="flex items-center gap-3">
      <a
        href={site.socials.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
        class="grid h-10 w-10 place-items-center rounded-full border border-line text-haze transition hover:border-accent/40 hover:bg-accent/10 hover:text-accent"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.55V9h3.57v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.22.79 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z" />
        </svg>
      </a>
      <a
        href={site.socials.github}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
        class="grid h-10 w-10 place-items-center rounded-full border border-line text-haze transition hover:border-accent/40 hover:bg-accent/10 hover:text-accent"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 .5C5.37.5 0 5.87 0 12.5c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58 0-.29-.01-1.04-.02-2.05-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.21.09 1.84 1.24 1.84 1.24 1.07 1.84 2.81 1.31 3.5 1 .11-.78.42-1.31.76-1.61-2.67-.3-5.47-1.34-5.47-5.95 0-1.31.47-2.39 1.24-3.23-.13-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6.01 0c2.29-1.55 3.3-1.23 3.3-1.23.66 1.66.25 2.88.12 3.18.77.84 1.23 1.92 1.23 3.23 0 4.62-2.81 5.64-5.49 5.94.43.37.81 1.1.81 2.22 0 1.61-.01 2.9-.01 3.29 0 .32.21.7.82.58A12.01 12.01 0 0 0 24 12.5C24 5.87 18.63.5 12 .5z" />
        </svg>
      </a>
    </div>

    <p class="text-sm text-haze/70">
      Designed &amp; built by <span class="font-medium text-mist">{site.designedBy}</span>
    </p>
  </div>
</footer>
