---
import type { Tech } from "../data/stack";
// Inline line-icon set for the tech stack. Keyed by Tech["icon"].
interface Props {
  name: Tech["icon"];
  class?: string;
}
const { name, class: className = "h-9 w-9" } = Astro.props;
const common = {
  viewBox: "0 0 24 24",
  fill: "none",
  stroke: "currentColor",
  "stroke-width": "1.6",
  "stroke-linecap": "round",
  "stroke-linejoin": "round",
  "aria-hidden": "true",
} as const;
---

{
  name === "java" && (
    <svg class={className} {...common}>
      <path d="M6 9h11v4a4 4 0 0 1-4 4h-3a4 4 0 0 1-4-4V9z" />
      <path d="M17 10h1.5a2 2 0 0 1 0 4H17" />
      <path d="M9 3c-.6 1 .6 1.6 0 2.8M12.5 3c-.6 1 .6 1.6 0 2.8" />
      <path d="M5 21h13" />
    </svg>
  )
}
{
  name === "spring" && (
    <svg class={className} {...common}>
      <path d="M4 19c0-8 6-14 16-15 1 9-5 16-15 15z" />
      <path d="M8 16c2.5-3.5 5.5-5.8 9-7" />
    </svg>
  )
}
{
  name === "database" && (
    <svg class={className} {...common}>
      <ellipse cx="12" cy="6" rx="7" ry="3" />
      <path d="M5 6v12c0 1.66 3.13 3 7 3s7-1.34 7-3V6" />
      <path d="M5 12c0 1.66 3.13 3 7 3s7-1.34 7-3" />
    </svg>
  )
}
{
  name === "git" && (
