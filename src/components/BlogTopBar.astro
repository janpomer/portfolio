---
import { site } from "../data/site";
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-line bg-ink/80 backdrop-blur-md">
  <nav class="mx-auto flex max-w-3xl items-center justify-between px-6 py-4">
    <!-- Brand → back to the portfolio -->
    <a
      href="/"
      class="group flex items-center gap-2 text-sm font-semibold tracking-tight text-mist"
    >
      <img
        src="/favicon.png"
        alt={`${site.name} monogram`}
        width="32"
        height="32"
        class="h-8 w-8 rounded-lg object-cover ring-1 ring-accent/30 transition group-hover:ring-accent/60"
      />
      <span>{site.name}</span>
    </a>

    <div class="flex items-center gap-1">
      <a
        href="/"
        class="rounded-full px-3 py-2 text-sm font-medium text-haze transition hover:bg-veil hover:text-mist"
      >
        ← Portfolio
      </a>

      <!-- Theme toggle (handler is global, in Layout.astro) -->
      <button
        type="button"
        class="grid h-9 w-9 place-items-center rounded-full text-haze ring-1 ring-line transition hover:bg-veil hover:text-mist"
        aria-label="Toggle color theme"
        data-theme-toggle
      >
        <svg class="theme-icon-sun h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4" />
          <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" />
        </svg>
        <svg class="theme-icon-moon h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" />
        </svg>
      </button>
    </div>
  </nav>
</header>
